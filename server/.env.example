# ========================
# MERN YouTube Automation - Environment Variables
# ========================

# Server
PORT=5000

# OpenRouter API (primary, free models) - https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Pexels API (free) - https://www.pexels.com/api/
PEXELS_API_KEY=

# Gemini API keys (fallback) - https://aistudio.google.com/apikey
# Add comma-separated keys for failover rotation
GEMINI_API_KEYS=key1,key2,key3

# YouTube OAuth2 - place client_secret.json in server/credentials/
# Get from: https://console.cloud.google.com/
